{
  // === Core Editor Settings ===
  "agent_servers": {
    "cursor": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "buffer_font_weight": 400.0,
  "context_server_timeout": 59,
  "edit_predictions": {
    "sweep": {
      "privacy_mode": true
    },
    "mode": "eager",
    "enabled_in_text_threads": true,
    "disabled_globs": [
      "**/.env*",
      "**/*.pem",
      "**/*.key",
      "**/*.cert",
      "**/*.crt",
      "**/secrets.yml",
      "cicd/*",
      "**/*.log"
    ]
  },
  "show_edit_predictions": true,
  "agent_ui_font_size": 18.0,
  "agent_buffer_font_size": 14.0,
  "ui_font_weight": 400.0,
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "icon_theme": {
    "mode": "light",
    "light": "Colored Zed Icons Theme Light",
    "dark": "Colored Zed Icons Theme Dark"
  },
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "always",
    "use_smartcase_find": true
  },

  // Font: Hack at 12pt (from opt.guifont)
  "buffer_font_family": "JetBrainsMono Nerd Font Propo",
  "buffer_font_size": 14,
  "ui_font_family": ".ZedSans",
  "ui_font_size": 17.0,

  // Text wrapping (from opt.wrap = true)
  "soft_wrap": "editor_width",

  // Theme: tokyonight
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Catppuccin Macchiato"
  },

  // Line numbers - relative for vim muscle memory
  "relative_line_numbers": "enabled",

  // Tab settings (LazyVim defaults)
  "tab_size": 2,
  "hard_tabs": false,

  // Auto-trim whitespace (replacing trim.nvim)
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,

  // Format on save
  "format_on_save": "on",

  // Tab bar (from opt.showtabline = 1)
  "tabs": {
    "git_status": true,
    "show_close_button": "hover"
  },
  "tab_bar": {
    "show_nav_history_buttons": false
  },

  // Hide whitespace characters (from opt.list = false)
  "show_whitespaces": "none",

  // Autosave
  "autosave": "on_focus_change",

  // Cursor
  "cursor_blink": false,

  // Scrolloff (vim-like)
  "vertical_scroll_margin": 8,

  // Git integration
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": false,
      "delay_ms": 500
    }
  },

  // Terminal settings
  "terminal": {
    "dock": "bottom",
    "shell": "system",
    "copy_on_select": true,
    "detect_venv": {
      "on": {
        "directories": [".env", ".venv", "venv"]
      }
    },
    "env": {
      "EDITOR": "zed --wait"
    }
  },

  // Project panel (replacing neo-tree)
  "project_panel": {
    "button": true,
    "dock": "left",
    "default_width": 240,
    "git_status": true,
    "auto_reveal_entries": true,
    "auto_fold_dirs": true,
    "file_icons": true,
    "folder_icons": true,
    "indent_size": 20
  },

  // Outline panel
  "outline_panel": {
    "dock": "right",
    "button": true
  },

  // Indent guides
  "indent_guides": {
    "enabled": true,
    "coloring": "fixed"
  },

  // Completion
  "show_completions_on_input": true,

  // === Language-Specific Configurations ===
  "languages": {
    // Python
    "Python": {
      "language_servers": ["ty", "ruff"],
      "format_on_save": "on"
    },
    // SQL/dbt - sqlfmt formatter
    "SQL": {
      "tab_size": 2,
      "formatter": {
        "external": {
          "command": "sqlfmt",
          "arguments": ["-"]
        }
      },
      "format_on_save": "on"
    }
  }
}
